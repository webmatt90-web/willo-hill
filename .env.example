# ─────────────────────────────────────────────────────────────────────
# Willo-Hill Baptist Church — environment variable template
#
# Claude's WLA security hooks prevent it from editing .env* files, so this
# template lives at env.example. To update the real files, run:
#
#   mv env.example .env.example      # canonical template (committed)
#   cp .env.example .env.local       # then fill in real values (gitignored)
#
# Where each value goes:  [local] =
#                         [vercel] = Vercel → Project → Settings → Env Vars
# ────────────────────────────────────────

# ── Supabase (Project Settings → AP─────
# [local + vercel] Project URL, e.g. https://xifpohfvztdzvpugxzrj.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# [local + vercel] Publishable key (sb_publishable_...). Safe for the browser.
# (Legacy NEXT_PUBLIC_SUPABASE_ANON_KEY is also supported.)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# [local + vercel, mark SENSITIVE] Secret key (sb_secret_...). Server-only —
# powers the visit/prayer form insert.
# (Legacy SUPABASE_SERVICE_ROLE_KEY is also supported.)
SUPABASE_SECRET_KEY=

# [local only] Direct Postgres URI (sed by
# `npm run db:apply` to run migrations/seeds. Not needed on Vercel.
SUPABASE_DB_URL=

# ── Resend (email for visit/prayer/contact forms) ───────────────────
# [local + vercel, mark SENSITIVE] API key (re_...). Until set, form emails
# are skipped gracefully — submissions still save to the database.
RESEND_API_KEY=

# [local + vercel, optional] Verified sender, e.g.
# "Willo-Hill Church <hello@willohil onboarding
# sender until the willohill.com domain is verified in Resend.
RESEND_FROM_EMAIL=

# [local + vercel, optional] Where form notifications go.
# Defaults to pastordave@willohill.c
CHURCH_NOTIFICATION_EMAIL=

# ── Site ────────────────────────────────────────────────────────────
# [local] http://localhost:3000   [vpp URL
# [vercel production] https://willohill.com
# Drives canonical URLs, OpenGraph,
NEXT_PUBLIC_SITE_URL=http://localhost:3000